{
  "productName": "epoch",
  "version": "0.2.0",
  "identifier": "com.epoch.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },

  config = {
    "model": model_name,
    "epochs": epochs,
    "batch_size": batch_size,
    "dataset_path": dataset_path,
    "timestamp": timestamp,
}
with open(os.path.join(run_dir, "config.json"), "w") as f:
    json.dump(config, f, indent=4)
  "app": {
    "windows": [
      {
        "title": "EPOQ",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; connect-src 'self' ws://localhost:3000 http://localhost:3000"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": ["python_backend/**/*"],
    "externalBin": []
  }
}
